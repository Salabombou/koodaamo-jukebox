{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Bot",
            "runtimeArgs": [
                "-r", "ts-node/register",
                "-r", "tsconfig-paths/register",
                "--inspect=0.0.0.0:9229"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "outputCapture": "std",
            "program": "${workspaceFolder}/src/index.ts"
        }
    ]
}