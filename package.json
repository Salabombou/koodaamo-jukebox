{
  "name": "koodaamo-jukebox",
  "version": "1.0.0",
  "description": "A discord activity for playing music from YouTube",
  "main": "src/server/index.ts",
  "type": "module",
  "scripts": {
    "build": "vite build --outDir build/client && vite build --outDir build/server --ssr src/server/index.ts",
    "start": "node build/server/index.js",
    "dev": "NODE_ENV=development concurrently --kill-others --restart-tries 0 \"vite\" \"nodemon\"",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "lint": "eslint"
  },
  "keywords": [
    "discord",
    "typescript",
    "vite",
    "react",
    "express"
  ],
  "author": "Salabombou",
  "license": "MIT",
  "dependencies": {
    "@discord/embedded-app-sdk": "^1.5.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.1",
    "@fortawesome/free-solid-svg-icons": "^6.7.1",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@vitejs/plugin-react": "^4.3.3",
    "async-mutex": "^0.5.0",
    "autoprefixer": "^10.4.20",
    "compression": "^1.7.4",
    "daisyui": "^4.12.13",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-ws": "^5.0.2",
    "hls.js": "^1.5.17",
    "mongoose": "^8.7.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0",
    "seedrandom": "^3.0.5",
    "tailwindcss": "^3.4.14",
    "uuid": "^10.0.0",
    "vite": "^5.4.9",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/compression": "^1.7.5",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.0",
    "@types/express-ws": "^3.0.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/seedrandom": "^3.0.8",
    "@types/ws": "^8.5.12",
    "concurrently": "^9.0.1",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "type-fest": "^4.26.1",
    "typescript-eslint": "^8.10.0"
  }
}
